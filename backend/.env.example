# Copy to .env for local server runs
NODE_ENV=production
PORT=3000

# ICE config
STUN_URL=stun:stun.l.google.com:19302
TURN_URL=turn:openrelay.metered.ca:80?transport=tcp
TURN_USERNAME=openrelayproject
TURN_CREDENTIAL=openrelayproject

# Optional dashboard/API auth token (required for /api/sync and control routes when set)
WS_AUTH_TOKEN=

# Allowed dashboard origin (recommended: your exact production dashboard URL)
DASHBOARD_URL=
# Optional comma-separated allowlist override (e.g. https://a.example.com,https://b.example.com)
CORS_ALLOWED_ORIGINS=
