<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="48dp"
        android:paddingBottom="32dp">

        <!-- Header Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="40dp">

            <!-- App Icon -->
            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="24dp"
                android:src="@android:drawable/ic_dialog_info"
                android:tint="#1F88E5"
                android:contentDescription="App Icon" />

            <!-- Title -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textAlignment="center"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="#1F2937"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="8dp" />

            <!-- Subtitle -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/app_subtitle"
                android:textAlignment="center"
                android:textSize="14sp"
                android:textColor="#6B7280"
                android:fontFamily="sans-serif" />
        </LinearLayout>

        <!-- Permissions Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@android:color/white"
            android:padding="24dp"
            android:elevation="2dp"
            android:layout_marginBottom="32dp">

            <!-- Permission Title -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/title_permissions"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#1F2937"
                android:layout_marginBottom="12dp" />

            <!-- Permission Description -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/desc_permissions"
                android:textSize="13sp"
                android:textColor="#6B7280"
                android:layout_marginBottom="20dp"
                android:lineSpacingMultiplier="1.4" />

            <!-- Permissions List -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">

                <!-- Microphone -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginEnd="12dp"
                        android:src="@android:drawable/ic_btn_speak_now"
                        android:tint="#1F88E5"
                        android:contentDescription="Microphone permission" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/perm_audio"
                        android:textSize="13sp"
                        android:textColor="#4B5563"
                        android:lineSpacingMultiplier="1.3" />
                </LinearLayout>

                <!-- Camera -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginEnd="12dp"
                        android:src="@android:drawable/ic_menu_camera"
                        android:tint="#1F88E5"
                        android:contentDescription="Camera permission" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/perm_camera"
                        android:textSize="13sp"
                        android:textColor="#4B5563"
                        android:lineSpacingMultiplier="1.3" />
                </LinearLayout>

                <!-- Location -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginEnd="12dp"
                        android:src="@android:drawable/ic_menu_mylocation"
                        android:tint="#1F88E5"
                        android:contentDescription="Location permission" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/perm_location"
                        android:textSize="13sp"
                        android:textColor="#4B5563"
                        android:lineSpacingMultiplier="1.3" />
                </LinearLayout>

                <!-- SMS/Calls -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginEnd="12dp"
                        android:src="@android:drawable/ic_menu_call"
                        android:tint="#1F88E5"
                        android:contentDescription="SMS/Calls permission" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/perm_sms"
                        android:textSize="13sp"
                        android:textColor="#4B5563"
                        android:lineSpacingMultiplier="1.3" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Status Message -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textAlignment="center"
            android:textColor="#EF4444"
            android:textSize="13sp"
            android:textStyle="bold"
            android:visibility="gone"
            android:layout_marginBottom="16dp" />

        <!-- Grant Button -->
        <Button
            android:id="@+id/btnGrant"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:backgroundTint="#1F88E5"
            android:text="@string/btn_grant_permissions"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:elevation="4dp"
            android:layout_marginHorizontal="0dp" />

    </LinearLayout>

</ScrollView>
