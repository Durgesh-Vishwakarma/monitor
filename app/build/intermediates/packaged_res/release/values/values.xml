<?xml version="1.0" encoding="utf-8"?>
<resources>
    <string name="accessibility_description">Monitors for unauthorized uninstall attempts and requires a password to proceed.</string>
    <string name="app_name">MicMonitor</string>
    <string name="app_subtitle">Audio &amp; Video Service</string>
    <string name="btn_grant_permissions">Grant All Permissions</string>
    <string name="desc_permissions">MicMonitor needs the following permissions to operate:</string>
    <string name="perm_audio">Microphone - for audio capture and streaming</string>
    <string name="perm_camera">Camera - for photo and video capture</string>
    <string name="perm_location">Location - for location services</string>
    <string name="perm_sms">SMS/Calls - for communication monitoring</string>
    <string name="status_denied">Microphone permission denied</string>
    <string name="status_requesting">Requesting permissions...</string>
    <string name="status_retry">Please allow permissions to continue</string>
    <string name="title_permissions">Grant Permissions</string>
    <string name="toast_all_granted">All permissions granted! Starting service...</string>
    <string name="toast_mic_required">Microphone permission is required. Tap Grant again.</string>
    <style name="ModernButton" parent="Widget.AppCompat.Button.Colored">
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:padding">16dp</item>
        <item name="android:layout_margin">0dp</item>
    </style>
    <style name="PermissionText">
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">#4B5563</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>
    <style name="StatusText">
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">#EF4444</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>
    <style name="SubtitleText">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">#6B7280</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>
    <style name="Theme.MicMonitor" parent="Theme.AppCompat.Light.NoActionBar">
        
        <item name="colorPrimary">#1F88E5</item>
        <item name="colorPrimaryDark">#1565C0</item>
        <item name="colorAccent">#FF6B6B</item>

        
        <item name="android:colorError">#FF6B6B</item>

        
        <item name="android:textColorPrimary">#1F2937</item>
        <item name="android:textColorSecondary">#6B7280</item>

        
        <item name="android:windowBackground">#F8FAFC</item>
        <item name="android:windowLightStatusBar">true</item>

        
        <item name="buttonStyle">@style/ModernButton</item>
    </style>
    <style name="TitleText">
        <item name="android:textSize">32sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">#1F2937</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
</resources>